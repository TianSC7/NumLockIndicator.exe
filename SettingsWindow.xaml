<Window x:Class="NumLockIndicator.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NumLock Indicator 设置"
        Width="440" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF8F9FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="外观设置"
                   FontSize="18" FontWeight="Bold" Foreground="#FF2C3E50"
                   FontFamily="Microsoft YaHei" Margin="0,0,0,16" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="字体：" />
        <ComboBox x:Name="FontFamilyCombo" Grid.Row="1" Grid.Column="1"
                  IsEditable="True" Height="30"
                  SelectionChanged="FontFamilyCombo_SelectionChanged" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="字体大小：" Margin="0,10,0,0" />
        <Grid Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="FontSizeSlider" Minimum="12" Maximum="72"
                    IsSnapToTickEnabled="True" TickFrequency="1"
                    VerticalAlignment="Center"
                    ValueChanged="FontSizeSlider_ValueChanged" />
            <Border Grid.Column="1" Background="#FFE9ECEF" CornerRadius="4" Margin="8,0,0,0">
                <TextBlock x:Name="FontSizeLabel"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" Foreground="#FF7F8C8D" />
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="窗口宽度：" Margin="0,10,0,0" />
        <TextBox x:Name="WindowWidthBox" Grid.Row="3" Grid.Column="1"
                 Margin="0,10,0,0" Height="30" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="窗口高度：" Margin="0,10,0,0" />
        <TextBox x:Name="WindowHeightBox" Grid.Row="4" Grid.Column="1"
                 Margin="0,10,0,0" Height="30" />

        <TextBlock Grid.Row="5" Grid.Column="0" Text="ON 文字：" Margin="0,10,0,0" />
        <TextBox x:Name="OnTextBox" Grid.Row="5" Grid.Column="1"
                 Margin="0,10,0,0" Height="30" />

        <TextBlock Grid.Row="6" Grid.Column="0" Text="OFF 文字：" Margin="0,10,0,0" />
        <TextBox x:Name="OffTextBox" Grid.Row="6" Grid.Column="1"
                 Margin="0,10,0,0" Height="30" />

        <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="预览" FontSize="13" Foreground="#FF7F8C8D"
                   FontFamily="Microsoft YaHei" Margin="0,16,0,6" />

        <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#FFDEE2E6" BorderThickness="1">
            <StackPanel>
                <Border x:Name="PreviewOnBorder" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                    <TextBlock x:Name="PreviewOnText"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </Border>
                <Border x:Name="PreviewOffBorder" CornerRadius="6" Padding="10,8">
                    <TextBlock x:Name="PreviewOffText"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </Border>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="应用" Width="88" Height="34"
                    Style="{StaticResource SecondaryButton}"
                    Click="ApplyButton_Click"
                    Margin="0,0,12,0" />
            <Button Content="取消" Width="88" Height="34"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click" IsCancel="True"
                    Margin="0,0,12,0" />
            <Button Content="保存" Width="88" Height="34"
                    Style="{StaticResource ModernButton}"
                    Click="OkButton_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
