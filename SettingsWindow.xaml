<Window x:Class="NumLockIndicator.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NumLock &amp; CapsLock Indicator 设置"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF8F9FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="外观设置"
                   FontSize="18" FontWeight="Bold" Foreground="#FF2C3E50"
                   FontFamily="Microsoft YaHei" Margin="0,0,0,16" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="字体：" VerticalAlignment="Center" />
        <ComboBox x:Name="FontFamilyCombo" Grid.Row="1" Grid.Column="1"
                  IsEditable="True" Height="30" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="字体大小：" VerticalAlignment="Center" Margin="0,10,0,0" />
        <Grid Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="FontSizeSlider" Minimum="12" Maximum="72"
                    IsSnapToTickEnabled="True" TickFrequency="1"
                    VerticalAlignment="Center" />
            <Border Grid.Column="1" Background="#FFE9ECEF" CornerRadius="4" Margin="8,0,0,0">
                <TextBlock x:Name="FontSizeLabel"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" Foreground="#FF7F8C8D" />
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="窗口宽度：" VerticalAlignment="Center" Margin="0,10,0,0" />
        <TextBox x:Name="WindowWidthBox" Grid.Row="3" Grid.Column="1"
                 Margin="0,10,0,0" Height="30" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="窗口高度：" VerticalAlignment="Center" Margin="0,10,0,0" />
        <TextBox x:Name="WindowHeightBox" Grid.Row="4" Grid.Column="1"
                 Margin="0,10,0,0" Height="30" />

        <Separator Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,16,0,8" />

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="NumLock 文字"
                   FontSize="14" FontWeight="SemiBold" Foreground="#FF2C3E50"
                   FontFamily="Microsoft YaHei" Margin="0,0,0,6" />

        <TextBlock Grid.Row="7" Grid.Column="0" Text="ON 文字：" VerticalAlignment="Center" />
        <TextBox x:Name="OnTextBox" Grid.Row="7" Grid.Column="1" Height="30" />

        <TextBlock Grid.Row="8" Grid.Column="0" Text="OFF 文字：" VerticalAlignment="Center" Margin="0,6,0,0" />
        <TextBox x:Name="OffTextBox" Grid.Row="8" Grid.Column="1" Margin="0,6,0,0" Height="30" />

        <TextBlock Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="CapsLock 文字"
                   FontSize="14" FontWeight="SemiBold" Foreground="#FF2C3E50"
                   FontFamily="Microsoft YaHei" Margin="0,14,0,6" />

        <TextBlock Grid.Row="10" Grid.Column="0" Text="ON 文字：" VerticalAlignment="Center" />
        <TextBox x:Name="CapsOnTextBox" Grid.Row="10" Grid.Column="1" Height="30" />

        <TextBlock Grid.Row="11" Grid.Column="0" Text="OFF 文字：" VerticalAlignment="Center" Margin="0,6,0,0" />
        <TextBox x:Name="CapsOffTextBox" Grid.Row="11" Grid.Column="1" Margin="0,6,0,0" Height="30" />

        <StackPanel Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="保存" Width="88" Height="34"
                    Style="{StaticResource ModernButton}"
                    Click="OkButton_Click" IsDefault="True"
                    Margin="0,0,12,0" />
            <Button Content="取消" Width="88" Height="34"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click" IsCancel="True"
                    Margin="0,0,12,0" />
            <Button Content="应用" Width="88" Height="34"
                    Style="{StaticResource SecondaryButton}"
                    Click="ApplyButton_Click" />
        </StackPanel>
    </Grid>
</Window>
